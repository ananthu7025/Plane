{
  "name": "plane-prop-backend",
  "version": "1.0.0",
  "description": "Plane & Prop Community Platform Backend API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build && node dist/index.js",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --loader ts-node/esm src/db/seed.ts",
    "db:seed:blogs": "node --loader ts-node/esm src/db/seedBlogPermissions.ts",
    "db:seed:mentorship": "node --loader ts-node/esm src/db/seedMentorshipPermission.ts",
    "db:clear": "node --loader ts-node/esm src/db/clear-db.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "community",
    "platform",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@azure/msal-node": "^5.2.3",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.22.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.1.0",
    "isomorphic-fetch": "^3.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "resend": "^3.5.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^2.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
