# ========== Application ==========
NODE_ENV=development
PORT=5000
LOG_LEVEL=INFO

# ========== Frontend URL (CORS) ==========
FRONTEND_URL=http://localhost:5173

# ========== Database ==========
# PostgreSQL Connection String
DATABASE_URL=postgresql://postgres:password@localhost:5432/plane_prop

# Connection Pool Settings (for 5k+ users/day)
DB_POOL_MAX=20          # Max connections
DB_POOL_MIN=5           # Min idle connections
DB_IDLE_TIMEOUT=30000   # Close idle after 30s (ms)
DB_CONNECTION_TIMEOUT=2000  # Fail fast (ms)

# ========== Redis (Optional, for distributed rate limiting) ==========
# Uncomment to enable Redis for distributed rate limiting
# REDIS_URL=redis://localhost:6379

# ========== JWT & Security ==========
# 32+ character random string for JWT signing
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars!
JWT_ACCESS_EXPIRY=1m
JWT_REFRESH_EXPIRY=7d
OTP_EXPIRY_MINUTES=15
BCRYPT_SALT_ROUNDS=10

# ========== Email Configuration ==========
# Using Resend for production-grade email delivery
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@planeprop.com

# ========== Cloudinary Configuration (for Newsletter PDFs) ==========
# For PDF storage and auto page extraction
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ========== AWS S3 (Optional, for file uploads) ==========
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name

# ========== Error Tracking (Optional) ==========
# Sentry or other error tracking service
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ========== Monitoring (Optional) ==========
# APM and monitoring configuration
# DATADOG_API_KEY=your-datadog-key
# NEW_RELIC_LICENSE_KEY=your-new-relic-key

# ========== Rate Limiting ==========
# Global rate limit: requests per minute per IP
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW=60000

# Auth rate limit: attempts per 15 minutes
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=900000

# ========== Session/Cookie Settings ==========
# For secure production deployment
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_HTTPONLY=true
# SESSION_COOKIE_SAMESITE=strict

# ========== Feature Flags (Optional) ==========
# FEATURE_EMAIL_VERIFICATION=true
# FEATURE_PASSWORD_RESET=true
# FEATURE_RATE_LIMITING=true
